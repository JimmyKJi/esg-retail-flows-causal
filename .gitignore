# Virtual environments
venv/
env/
.venv/
.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints
.virtual_documents/

# Data — raw and intermediate data are NOT committed; only the lineage doc and
# processed summary outputs small enough to track. Raw pulls and interim caches
# are reproducible from `make data`; their provenance lives in DATA_LINEAGE.md.
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep
!data/DATA_LINEAGE.md

# Large model artefacts
*.pkl
*.joblib
*.h5

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Credentials
*.env
credentials.json
secrets/

# Results — keep final figures/tables/CSVs; exclude intermediate + run logs
results/figures/*.tmp
results/tables/*.tmp
results/*.log
